# Required: your OpenAI API key with access to the Realtime Translation model.
OPENAI_API_KEY=sk-...

# Optional: target language for the translation (BCP-47 / ISO code). Default: en
TARGET_LANGUAGE=en

# Optional: transcription model that enables the original-language transcript
# (the /source page). Try gpt-4o-transcribe (default), gpt-4o-mini-transcribe,
# or whisper-1. Set to empty to disable the source transcript entirely.
INPUT_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Optional: a stable, hashed identifier for the end user (sent as the
# OpenAI-Safety-Identifier header). Leave blank to omit.
OPENAI_SAFETY_IDENTIFIER=

# Optional: port for the local web server. Default: 3000
PORT=3000

# Optional: host to bind. Default: 127.0.0.1
HOST=127.0.0.1

# Optional: pino log level (trace|debug|info|warn|error|fatal). Default: info
LOG_LEVEL=info

# Optional: single log file (JSON, always appended, never rotated).
# Default: ./logs/app.log
LOG_FILE=./logs/app.log

# Optional: directory for saved transcripts. Default: ./transcripts
# TRANSCRIPT_DIR=./transcripts
